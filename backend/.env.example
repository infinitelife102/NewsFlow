# ============================================
# Supabase Configuration
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ============================================
# AI Model APIs (OpenRouter — free models)
# ============================================
# Get key: https://openrouter.ai/keys — free models: https://openrouter.ai/models?free=true
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional: your public app URL for OpenRouter rankings
# OPENROUTER_HTTP_REFERER=https://localhost:3000
# Summaries + default text chat (Llama 3.3 8B free — good JSON-style answers)
OPENROUTER_MODEL=minimax/minimax-m2.5:free
# Chat with images: free pool router picks a vision-capable free model
OPENROUTER_CHAT_VISION_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
# Chat with voice (OpenRouter input_audio); also used when both images and voice (omni)
# Free Nemotron Omni: do not send confidential voice per NVIDIA/OpenRouter terms
OPENROUTER_CHAT_AUDIO_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
# Optional text-only chat override (defaults to OPENROUTER_MODEL)
# OPENROUTER_CHAT_TEXT_MODEL=
CHAT_MAX_MESSAGES=32
CHAT_MAX_TOKENS=2048
CHAT_MAX_KEYFRAMES=5
CHAT_MAX_IMAGE_BYTES=4194304
CHAT_MAX_AUDIO_BYTES=8388608
CHAT_TEMPERATURE=0.6

# ============================================
# News Sources
# ============================================
# NewsAPI (Free tier: 100 requests/day)
# Get key at: https://newsapi.org/
NEWSAPI_KEY=your-newsapi-key

# ============================================
# Application Settings
# ============================================
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ============================================
# Processing Settings
# ============================================
# Clustering
CLUSTER_SIMILARITY_THRESHOLD=0.85
CLUSTER_MIN_SIZE=2
CLUSTER_ALGORITHM=hdbscan

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Summarization (OpenRouter)
SUMMARY_MAX_TOKENS=1024
SUMMARY_TEMPERATURE=0.3

# Crawling
CRAWL_INTERVAL_MINUTES=30
MAX_ARTICLES_PER_CRAWL=50
REQUEST_TIMEOUT=30
USER_AGENT=NewsFlow Bot 1.0

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=60
